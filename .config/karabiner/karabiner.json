{
    "global": {
        "check_for_updates_on_startup": false,
        "show_in_menu_bar": false
    },
    "profiles": [
        {
            "complex_modifications": {
                "rules": [
                    {
                        "description": "[Built-in][Nuphy] Left Ctrl(tap) => Esc",
                        "manipulators": [
                            {
                                "conditions": [
                                    {
                                        "identifiers": [
                                            { "is_built_in_keyboard": true },
                                            {
                                                "description": "Nuphy",
                                                "vendor_id": 2007
                                            }
                                        ],
                                        "type": "device_if"
                                    }
                                ],
                                "from": {
                                    "key_code": "left_control",
                                    "modifiers": { "optional": ["any"] }
                                },
                                "to": [{ "key_code": "left_control" }],
                                "to_if_alone": [
                                    {
                                        "hold_down_milliseconds": 200,
                                        "key_code": "escape"
                                    }
                                ],
                                "type": "basic"
                            }
                        ]
                    },
                    {
                        "description": "[Built-in] left_shift + right_shift => caps_lock",
                        "manipulators": [
                            {
                                "conditions": [
                                    {
                                        "identifiers": [{ "is_built_in_keyboard": true }],
                                        "type": "device_if"
                                    }
                                ],
                                "from": {
                                    "key_code": "left_shift",
                                    "modifiers": {
                                        "mandatory": ["right_shift"],
                                        "optional": ["caps_lock"]
                                    }
                                },
                                "to": [{ "key_code": "caps_lock" }],
                                "type": "basic"
                            },
                            {
                                "conditions": [
                                    {
                                        "identifiers": [{ "is_built_in_keyboard": true }],
                                        "type": "device_if"
                                    }
                                ],
                                "from": {
                                    "key_code": "right_shift",
                                    "modifiers": {
                                        "mandatory": ["left_shift"],
                                        "optional": ["caps_lock"]
                                    }
                                },
                                "to": [{ "key_code": "caps_lock" }],
                                "type": "basic"
                            }
                        ]
                    },
                    {
                        "description": "Disable the accidental keystroke prevention of Caps Lock",
                        "enabled": false,
                        "manipulators": [
                            {
                                "from": {
                                    "key_code": "caps_lock",
                                    "modifiers": { "optional": ["any"] }
                                },
                                "to": [
                                    {
                                        "hold_down_milliseconds": 100,
                                        "key_code": "caps_lock"
                                    },
                                    { "key_code": "vk_none" }
                                ],
                                "type": "basic"
                            }
                        ]
                    },
                    {
                        "description": "[Any][US Int] `/~ one keystroke",
                        "manipulators": [
                            {
                                "conditions": [
                                    {
                                        "input_sources": [{ "input_source_id": "^com\\.apple\\.keylayout\\.USInternational-PC$" }],
                                        "type": "input_source_if"
                                    }
                                ],
                                "from": { "key_code": "grave_accent_and_tilde" },
                                "to": [
                                    {
                                        "key_code": "grave_accent_and_tilde",
                                        "repeat": false
                                    },
                                    {
                                        "key_code": "spacebar",
                                        "repeat": false
                                    }
                                ],
                                "type": "basic"
                            },
                            {
                                "conditions": [
                                    {
                                        "input_sources": [{ "input_source_id": "^com\\.apple\\.keylayout\\.USInternational-PC$" }],
                                        "type": "input_source_if"
                                    }
                                ],
                                "from": {
                                    "key_code": "grave_accent_and_tilde",
                                    "modifiers": {
                                        "mandatory": ["shift"],
                                        "optional": ["caps_lock"]
                                    }
                                },
                                "to": [
                                    {
                                        "key_code": "grave_accent_and_tilde",
                                        "modifiers": ["shift"],
                                        "repeat": false
                                    },
                                    {
                                        "key_code": "spacebar",
                                        "repeat": false
                                    }
                                ],
                                "type": "basic"
                            }
                        ]
                    },
                    {
                        "description": "[Any] Left Shift(tap tap) => CapsLock",
                        "manipulators": [
                            {
                                "conditions": [
                                    {
                                        "name": "left_shift pressed",
                                        "type": "variable_if",
                                        "value": 1
                                    }
                                ],
                                "from": {
                                    "key_code": "left_shift",
                                    "modifiers": { "optional": ["any"] }
                                },
                                "to": [{ "key_code": "caps_lock" }],
                                "type": "basic"
                            },
                            {
                                "from": {
                                    "key_code": "left_shift",
                                    "modifiers": { "optional": ["any"] }
                                },
                                "parameters": { "basic.to_delayed_action_delay_milliseconds": 400 },
                                "to": [
                                    {
                                        "set_variable": {
                                            "name": "left_shift pressed",
                                            "value": 1
                                        }
                                    },
                                    { "key_code": "left_shift" }
                                ],
                                "to_delayed_action": {
                                    "to_if_canceled": [
                                        {
                                            "set_variable": {
                                                "name": "left_shift pressed",
                                                "value": 0
                                            }
                                        }
                                    ],
                                    "to_if_invoked": [
                                        {
                                            "set_variable": {
                                                "name": "left_shift pressed",
                                                "value": 0
                                            }
                                        }
                                    ]
                                },
                                "type": "basic"
                            }
                        ]
                    },
                    {
                        "description": "[Any] CapsLock(held) => Hyper: ⌃⌥⇧⌘",
                        "manipulators": [
                            {
                                "from": { "key_code": "caps_lock" },
                                "to": [
                                    {
                                        "key_code": "left_shift",
                                        "modifiers": ["left_command", "left_control", "left_option"]
                                    }
                                ],
                                "to_if_alone": [
                                    {
                                        "hold_down_milliseconds": 200,
                                        "key_code": "caps_lock"
                                    }
                                ],
                                "type": "basic"
                            }
                        ]
                    },
                    {
                        "description": "[Any][!Emacs] Ctrl+p/n => Up/Down",
                        "manipulators": [
                            {
                                "conditions": [
                                    {
                                        "bundle_identifiers": [
                                            "^org\\.gnu\\.Emacs"
                                        ],
                                        "type": "frontmost_application_unless"
                                    }
                                ],
                                "from": {
                                    "key_code": "p",
                                    "modifiers": { "mandatory": ["control"] }
                                },
                                "to": [{ "key_code": "up_arrow" }],
                                "type": "basic"
                            },
                            {
                                "conditions": [
                                    {
                                        "bundle_identifiers": [
                                            "^org\\.gnu\\.Emacs"
                                        ],
                                        "type": "frontmost_application_unless"
                                    }
                                ],
                                "from": {
                                    "key_code": "n",
                                    "modifiers": { "mandatory": ["control"] }
                                },
                                "to": [{ "key_code": "down_arrow" }],
                                "type": "basic"
                            }
                        ]
                    }
                ]
            },
            "devices": [
                {
                    "identifiers": {
                        "is_keyboard": true,
                        "is_pointing_device": true,
                        "product_id": 45086,
                        "vendor_id": 1133
                    },
                    "ignore": false,
                    "mouse_flip_vertical_wheel": true,
                    "simple_modifications": [
                        {
                            "from": { "pointing_button": "button4" },
                            "to": [{ "key_code": "mission_control" }]
                        },
                        {
                            "from": { "pointing_button": "button5" },
                            "to": [{ "key_code": "mission_control" }]
                        }
                    ]
                },
                {
                    "identifiers": {
                        "is_keyboard": true,
                        "is_pointing_device": true,
                        "product_id": 694,
                        "vendor_id": 13364
                    },
                    "ignore": false
                },
                {
                    "identifiers": { "is_keyboard": true },
                    "simple_modifications": [
                        {
                            "from": { "key_code": "caps_lock" },
                            "to": [{ "key_code": "left_control" }]
                        },
                        {
                            "from": { "key_code": "left_control" },
                            "to": [{ "key_code": "caps_lock" }]
                        },
                        {
                            "from": { "key_code": "non_us_backslash" },
                            "to": [{ "key_code": "grave_accent_and_tilde" }]
                        }
                    ]
                },
                {
                    "identifiers": {
                        "is_pointing_device": true,
                        "product_id": 50479,
                        "vendor_id": 1133
                    },
                    "ignore": false,
                    "mouse_flip_vertical_wheel": true
                },
                {
                    "identifiers": {
                        "is_keyboard": true,
