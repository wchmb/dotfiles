# Set default values for all the accounts.
defaults
auth on
tls on
tls_trust_file /opt/homebrew/etc/openssl@3/cert.pem
logfile ~/.maildir/msmtp.log

# iCloud
account icloud
host smtp.mail.me.com
port 587
protocol smtp
from alebdm@icloud.com
user alebdm
passwordeval security find-generic-password -s mu4e-icloud -a alebdm -w

# Gmail
account gmail
host smtp.gmail.com
port 587
protocol smtp
from alejandro@fasts3.io
user alejandro@fasts3.io
passwordeval "security find-generic-password -s mu4e-gmail -a alejandro -w"

account default : icloud
