tap "wchmb/subsurface", "git@github.com:wchmb/homebrew-subsurface.git"
brew "shellcheck"
brew "actionlint"
brew "autoconf"
brew "automake"
brew "fontconfig"
brew "glib"
brew "cmake"
brew "coreutils"
brew "fd"
brew "openssl@3"
brew "ffmpeg"
brew "gnu-sed"
brew "python@3.13"
brew "graphviz"
brew "hunspell"
brew "imagemagick"
brew "isync"
brew "libgccjit"
brew "libvterm"
brew "lmdb"
