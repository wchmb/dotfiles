brew "mu"
brew "openjdk"
brew "pkgconf"
brew "pngpaste"
brew "poppler"
brew "ripgrep"
brew "shfmt"
brew "ucspi-tcp"
brew "watch"
brew "wget"
brew "yt-dlp"
brew "d12frosted/emacs-plus/emacs-plus@30", args: ["with-c9rgreen-sonoma-icon", "with-imagemagick", "with-native-comp", "with-no-frame-refocus"]
